#!/bin/sh -e

export DESTDIR="$1"
export PKG_CONFIG_PATH=/usr/lib/pkgconfig

patch -p1 < 0001-fix-enum-types-for-muon.patch

: > tests/meson.build
: > po/meson.build

muon setup \
	-Dprefix=/usr \
	-Dsysconfdir=/etc \
	-Dmandir=/usr/share/man \
	-Dbuildtype=release \
	-Db_colorout=never \
	-Ddocs=false \
	-Dintrospection=false \
	-Ddefault_library=shared \
	build

samu -C build
muon -C build install
