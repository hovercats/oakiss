#!/bin/sh -e

export DESTDIR="$1"

patch -p1 < 0001-remove-the-need-for-vulkan-headers.patch

muon setup \
    -Dprefix=/usr \
    -Dbuildtype=release \
    -Dvulkan=disabled \
    -Ddemos=false \
    -Dopengl=disabled \
    -Ddefault_library=shared \
    output

samu -C output
muon -C output install
