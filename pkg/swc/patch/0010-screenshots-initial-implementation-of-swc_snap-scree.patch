+#endif
 error14:
 	wl_global_destroy(swc.panel_manager);
-#endif
 error13:
 	wl_global_destroy(swc.kde_decoration_manager);
 error12:
@@ -266,6 +275,7 @@ swc_finalize(void)
 #ifdef ENABLE_XWAYLAND
 	xserver_finalize();
 #endif
+	wl_global_destroy(swc.snap_manager);
 	wl_global_destroy(swc.panel_manager);
 	wl_global_destroy(swc.xdg_decoration_manager);
 	wl_global_destroy(swc.xdg_shell);
diff --git a/protocol/swc_snap.xml b/protocol/swc_snap.xml
new file mode 100644
index 0000000..e8d8622
--- /dev/null
+++ b/protocol/swc_snap.xml
@@ -0,0 +1,15 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<protocol name="swc_snap">
+    <interface name="swc_snap" version="1">
+        <description summary="simple screenshot to file descriptor">
+            provides a minimal screenshot capability.
+        </description>
+
+        <request name="capture">
+            <description summary="capture screenshot to fd">
+                captures the current screen and writes it as ppm formay
+            </description>
+            <arg name="fd" type="fd" summary="file descriptor to write ppm data"/>
+        </request>
+    </interface>
+</protocol>
